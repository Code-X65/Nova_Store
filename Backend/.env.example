NODE_ENV=development
PORT=5000
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
DATABASE_URL="postgres://postgres:password@your-project-db.supabase.co:5432/postgres"
JWT_ACCESS_SECRET="your-access-token-secret"
JWT_REFRESH_SECRET="your-refresh-token-secret"
REFRESH_TOKEN_COOKIE_NAME="refreshToken"
REFRESH_TOKEN_COOKIE_OPTIONS="httpOnly=true,secure=true,sameSite=strict,maxAge=2592000"
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
VERIFICATION_TOKEN_EXPIRY=86400
PASSWORD_RESET_TOKEN_EXPIRY=3600
CLIENT_URL="http://localhost:5173"
EMAIL_FROM="noreply@yourstore.com"
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT=587
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-pass"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:5000/api/v1/auth/oauth/google/callback"
# SuperAdmin Bootstrap (used by seed-superadmin.js)
SUPER_ADMIN_EMAIL="superadmin@yourstore.com"

# Invitation System
INVITE_TOKEN_EXPIRY_DAYS=7      # Invitation link lifetime in days
FRONTEND_URL="http://localhost:3000"  # Base URL for invitation accept links
STORE_NAME="Nova Store"               # Used in invitation email templates

DEFAULT_TAX_RATE=0.075
SHIPPING_COST_STANDARD=1500
SHIPPING_COST_EXPRESS=3500

# Twilio Configuration
TWILIO_ACCOUNT_SID="your-twilio-sid"
TWILIO_AUTH_TOKEN="your-twilio-auth-token"
TWILIO_FROM_NUMBER="+1234567890"

# Phone OTP Configuration
PHONE_OTP_EXPIRY_SECONDS=600         # 10-minute OTP expiry (default)
PHONE_OTP_MAX_ATTEMPTS=5             # max failed OTP tries
REFERRAL_CODE_LENGTH=12              # generated referral code length
SMS_SENDER_NAME=NovaStore            # Twilio sender name display

# Supabase Storage — Return Evidence
# Create this bucket in your Supabase project dashboard (Storage → New bucket)
# Set it to public so URLs are accessible by customers and admins
SUPABASE_RETURN_EVIDENCE_BUCKET=return-evidence
